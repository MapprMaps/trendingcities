---
import Base from '../../layouts/Base.astro';
import { cities } from '../../lib/data';
const MAPTILER_KEY = 'OdgircU0GgQPcolbaKt8'; // domain-restricted to trendingcities.com
const withCoords = cities.filter((c) => typeof c.lat === 'number').length;
---
<Base
  title="Map — home prices across the world | TrendingCities"
  description="Every city in the dataset on one map, coloured by affordability. Green is cheaper, red is pricier. Click a city for its prices."
  path="/map/"
>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/maplibre-gl@4.7.1/dist/maplibre-gl.css" />

  <section class="page-head">
    <div class="container">
      <div class="breadcrumb"><a href="/">Home</a><span>/</span><span>Map</span></div>
      <span class="tc-label" style="color:var(--primary-fg)">Explore</span>
      <h1 class="tc-h1">The map</h1>
      <p>{withCoords} cities, coloured by 3-bedroom affordability vs the global median. Click a marker for prices.</p>
    </div>
  </section>

  <section class="container" style="padding-bottom:48px">
    <div id="tc-map" style="height:72vh;min-height:420px;border:1px solid var(--border);border-radius:var(--r-xl);overflow:hidden"></div>
    <div class="chips-row" style="margin-top:14px;align-items:center">
      <span class="tc-label">Affordability (3-bed)</span>
      <span class="tc-chip"><span style="display:inline-block;width:10px;height:10px;border-radius:50%;background:#15A04A;margin-right:6px"></span>very affordable</span>
      <span class="tc-chip"><span style="display:inline-block;width:10px;height:10px;border-radius:50%;background:#F0A327;margin-right:6px"></span>around median</span>
      <span class="tc-chip"><span style="display:inline-block;width:10px;height:10px;border-radius:50%;background:#C23A2B;margin-right:6px"></span>very expensive</span>
    </div>
  </section>

  <script is:inline src="https://cdn.jsdelivr.net/npm/maplibre-gl@4.7.1/dist/maplibre-gl.js"></script>
  <script is:inline define:vars={{ MAPTILER_KEY }}>
    const map = new maplibregl.Map({
      container: 'tc-map',
      style: `https://api.maptiler.com/maps/${document.documentElement.dataset.theme==='dark'?'dataviz-dark':'dataviz-light'}/style.json?key=${MAPTILER_KEY}`,
      center: [10, 25],
      zoom: 1.4,
      attributionControl: { compact: true },
    });
    map.addControl(new maplibregl.NavigationControl({ showCompass: false }), 'top-right');
    map.on('load', async () => {
      const data = await (await fetch('/cities.geojson')).json();
      map.addSource('cities', { type: 'geojson', data });
      map.addLayer({
        id: 'city-dots', type: 'circle', source: 'cities',
        paint: {
          'circle-radius': ['interpolate', ['linear'], ['zoom'], 1, 3.5, 5, 6, 10, 9],
          'circle-color': ['get', 'color'],
          'circle-stroke-width': 1, 'circle-stroke-color': '#ffffff', 'circle-opacity': 0.9,
        },
      });
      const popup = new maplibregl.Popup({ closeButton: false, offset: 10 });
      map.on('mouseenter', 'city-dots', (e) => {
        map.getCanvas().style.cursor = 'pointer';
        const p = e.features[0].properties;
        popup.setLngLat(e.lngLat).setHTML(
          `<div style="font:600 14px Geist Variable,system-ui,sans-serif;color:#0F1B2D">${p.name}</div>`
          + `<div style="font:12px Geist Variable,system-ui;color:#45566B">${p.country} · <b>${p.price}</b> (3-bed)</div>`
        ).addTo(map);
      });
      map.on('mouseleave', 'city-dots', () => { map.getCanvas().style.cursor = ''; popup.remove(); });
      map.on('click', 'city-dots', (e) => { window.location.href = e.features[0].properties.url; });
    });
  </script>
</Base>
