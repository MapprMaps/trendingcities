---
import Base from '../../../layouts/Base.astro';
import MetricRankingTable from '../../../components/MetricRankingTable.astro';
import { rankByMetric } from '../../../lib/data';

const rows = rankByMetric('local_purchasing_power_index', 'desc');
const jsonLd = {
  '@context': 'https://schema.org', '@type': 'ItemList',
  name: 'Cities with the highest local purchasing power',
  itemListElement: rows.slice(0, 25).map((c, i) => ({
    '@type': 'ListItem', position: i + 1, name: `${c.city}, ${c.country}`,
    url: `https://www.trendingcities.com${c.url}`,
  })),
};
---
<Base
  title="Cities with the highest purchasing power (2026) | TrendingCities"
  description={`Where local salaries stretch furthest — ranked on the Numbeo Local Purchasing Power Index (New York City = 100). ${rows.length} cities with data.`}
  path="/rankings/highest-purchasing-power/"
  jsonLd={jsonLd}
>
  <section class="page-head">
    <div class="container">
      <div class="breadcrumb"><a href="/">Home</a><span>/</span><span>Rankings</span></div>
      <span class="tc-label" style="color:var(--primary)">Ranking · highest purchasing power</span>
      <h1 class="tc-h1">Highest local purchasing power</h1>
      <p>Ranked by the Numbeo Local Purchasing Power Index (New York City = 100), highest first — across {rows.length} cities with data. A higher index means a typical local salary buys more, after local prices. This is the “prices read against earnings” view.</p>
    </div>
  </section>
  <section class="section" style="padding-top:24px">
    <div class="container">
      <MetricRankingTable rows={rows} highlight="local_purchasing_power_index" limit={100} />
      <div class="tc-callout tc-callout--source" style="margin-top:24px">
        <span data-lucide="info" aria-hidden="true"></span>
        <div><strong>How this is ranked.</strong> Cities sorted by the Numbeo Local Purchasing Power Index (NYC = 100), descending. Each city page shows the same figure with its source and “last updated” date. <a href="/data/" style="color:var(--primary)">Methodology →</a></div>
      </div>
    </div>
  </section>
</Base>
