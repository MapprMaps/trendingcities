---
import Base from '../../layouts/Base.astro';
import CityCard from '../../components/CityCard.astro';
import { cities, vsMedian, relatedTo, districtsOf, medians, DATA_UPDATED, DATA_VERSION, METRIC_META, METRIC_GROUP_LABEL, SOURCE_LABEL, asOfLabel, type City } from '../../lib/data';
import { usd, usdShort, pct, fmtMetric } from '../../lib/format';

export function getStaticPaths() {
  return cities.map((c) => ({ params: { slug: c.slug }, props: { city: c } }));
}

const { city } = Astro.props as { city: City };
const related = relatedTo(city);
const districts = city.isDistrict ? [] : districtsOf(city.slug);
const parentCity = city.isDistrict ? cities.find((c) => c.slug === city.parentSlug) : undefined;
// Short leaf label for breadcrumbs: "Berlin (Mitte)" -> "Mitte"
const leaf = city.isDistrict ? (city.city.match(/\(([^)]+)\)/)?.[1] ?? city.city) : city.city;

const beds = [
  { key: 'one' as const, label: '1-bedroom', price: city.one },
  { key: 'two' as const, label: '2-bedroom', price: city.two },
  { key: 'three' as const, label: '3-bedroom', price: city.three },
];

const d3 = vsMedian(city.three, 'three');
const cheaper = d3 < 0;
const summary = cheaper
  ? `${city.city} is more affordable than most of the dataset. A 3-bedroom home runs about ${pct(d3)} versus the global median of ${usdShort(medians.three)}.`
  : `${city.city} is one of the pricier markets here. A 3-bedroom home runs about ${pct(d3)} versus the global median of ${usdShort(medians.three)}.`;

// Non-price metrics present on this record, grouped for rendering. Each renders
// generically with its own source + "last updated" badge (the freshness signal).
const metricGroups = (['cost', 'income', 'quality', 'demographics'] as const)
  .map((g) => ({
    key: g,
    label: METRIC_GROUP_LABEL[g],
    items: METRIC_META.filter((m) => m.group === g && city.metricsRaw[m.key]).map((m) => ({
      meta: m,
      mv: city.metricsRaw[m.key],
    })),
  }))
  .filter((grp) => grp.items.length > 0);

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Place',
  name: `${city.city}, ${city.country}`,
  address: { '@type': 'PostalAddress', addressLocality: city.city, addressCountry: city.country },
  url: `https://www.trendingcities.com${city.url}`,
};
const SITE = 'https://www.trendingcities.com';
// Build crumbs dynamically: Home / Country / [Parent city, if district] / This place.
// Every itemListElement gets an `item` URL (Google requires it on all but the last;
// we set it on all to be safe and avoid the "Missing field 'item'" error).
const crumbTrail = [
  { name: 'Home', url: `${SITE}/` },
  { name: city.country, url: `${SITE}/country/${city.countrySlug}/` },
  ...(city.isDistrict && parentCity ? [{ name: parentCity.city, url: `${SITE}${parentCity.url}` }] : []),
  { name: city.isDistrict ? leaf : city.city, url: `${SITE}${city.url}` },
];
const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: crumbTrail.map((c, i) => ({
    '@type': 'ListItem', position: i + 1, name: c.name, item: c.url,
  })),
};
---
<Base
  title={`${city.city}, ${city.country} home prices — 1, 2 & 3-bed medians | TrendingCities`}
  description={`Median home prices in ${city.city}, ${city.country}: 1-bed ${usd(city.one)}, 2-bed ${usd(city.two)}, 3-bed ${usd(city.three)}. See how ${city.city} compares to the global median.`}
  path={city.url}
  ogType="article"
  jsonLd={[jsonLd, breadcrumbLd]}
>
  {city.hero ? (
    <section class="city-hero">
      <img src={city.hero.url} alt={`${city.city}, ${city.country}`} loading="eager" decoding="async" crossorigin="anonymous" />
      <div class="city-hero__scrim"></div>
      <div class="city-hero__overlay">
        <div class="container">
          <div class="breadcrumb breadcrumb--photo">
            <a href="/">Home</a><span>/</span><a href={`/country/${city.countrySlug}/`}>{city.country}</a><span>/</span>{city.isDistrict && parentCity && (<><a href={parentCity.url}>{parentCity.city}</a><span>/</span></>)}<span>{leaf}</span>
          </div>
          <h1 class="tc-h1">{city.city}</h1>
          <div class="affordline">
            <span class="tc-secondary" style="color:rgba(255,255,255,.85)">{city.country}</span>
            <span class={`tc-badge ${cheaper ? 'tc-badge--park' : 'tc-badge--down'}`}>
              {cheaper ? 'Below global median' : 'Above global median'} · {pct(d3)} (3-bed)
            </span>
          </div>
        </div>
      </div>
      <span class="city-hero__credit">
        Photo: {city.hero.username && city.hero.source === 'unsplash'
          ? <a href={`https://unsplash.com/@${city.hero.username}?utm_source=trendingcities&utm_medium=referral`} target="_blank" rel="noopener nofollow">{city.hero.photographer}</a>
          : (city.hero.photographer || 'Unknown')}
        {' / '}
        {city.hero.source === 'unsplash'
          ? <a href="https://unsplash.com/?utm_source=trendingcities&utm_medium=referral" target="_blank" rel="noopener nofollow">Unsplash</a>
          : (city.hero.source === 'flickr' ? 'Flickr' : city.hero.source)}
      </span>
    </section>
    <section class="section" style="padding-block:28px 0">
      <div class="container"><p class="tc-lg tc-secondary" style="max-width:680px;margin:0">{summary}</p></div>
    </section>
  ) : (
    <section class="page-head">
      <div class="container">
        <div class="breadcrumb">
          <a href="/">Home</a><span>/</span>
          <a href={`/country/${city.countrySlug}/`}>{city.country}</a><span>/</span>
          {city.isDistrict && parentCity && (<><a href={parentCity.url}>{parentCity.city}</a><span>/</span></>)}
          <span style="color:var(--fg-2)">{leaf}</span>
        </div>
        <h1 class="tc-h1">{city.city}</h1>
        <div class="affordline">
          <span class="tc-secondary">{city.country}</span>
          <span class={`tc-badge ${cheaper ? 'tc-badge--park' : 'tc-badge--down'}`}>
            {cheaper ? 'Below global median' : 'Above global median'} · {pct(d3)} (3-bed)
          </span>
        </div>
        <p class="tc-lg tc-secondary" style="max-width:680px;margin-top:14px">{summary}</p>
      </div>
    </section>
  )}

  <section class="section" style="padding-top:28px">
    <div class="container">
      <span class="tc-label" style="display:block;margin-bottom:12px">Median purchase price</span>
      <div class="grid grid--prices">
        {beds.map((b) => {
          const diff = vsMedian(b.price, b.key);
          const below = diff < 0;
          return (
            <div class="tc-card pricecard">
              <span class="tc-label">{b.label}</span>
              <span class="pricecard__val">{usd(b.price)}</span>
              <span class="pricecard__sub">
                <span class={`tc-delta ${below ? 'tc-delta--up' : 'tc-delta--down'}`}>{pct(diff)}</span>
                vs global median {usdShort(medians[b.key])}
              </span>
            </div>
          );
        })}
      </div>
    </div>
  </section>

  {metricGroups.map((grp) => (
    <section class="section" style="padding-top:0">
      <div class="container">
        <span class="tc-label" style="display:block;margin-bottom:12px">{grp.label}</span>
        <div class="grid grid--metrics">
          {grp.items.map(({ meta, mv }) => (
            <div class="tc-card metriccard">
              <span class="tc-label">{meta.label}</span>
              <span class="metriccard__val">{fmtMetric(mv.value, meta.fmt)}</span>
              {meta.baseline && <span class="metriccard__base">{meta.baseline}</span>}
              <span class="metriccard__prov">
                <span class="metriccard__src">{(mv.sources || []).map((s) => SOURCE_LABEL[s] || s).join(' · ')}</span>
                {mv.as_of && <span class="metriccard__date">Updated {asOfLabel(mv.as_of)}</span>}
                {mv.confidence && <span class={`tc-conf tc-conf--${mv.confidence}`}>{mv.confidence} confidence</span>}
              </span>
            </div>
          ))}
        </div>
      </div>
    </section>
  ))}

  <section class="section" style="padding-top:0">
    <div class="container">
      <div class="tc-callout tc-callout--source">
        <span data-lucide="database" aria-hidden="true"></span>
        <div>
          <strong>Source &amp; date.</strong> Median home-purchase prices in USD, starter dataset v{DATA_VERSION} ({DATA_UPDATED}). Other metrics carry their own source &amp; date on each card above. Directional figures for comparing markets — not a valuation of any specific property. <a href="/data/" style="color:var(--primary)">Methodology →</a>
        </div>
      </div>
    </div>
  </section>

  {districts.length > 0 && (
    <section class="section" style="padding-top:0">
      <div class="container">
        <div class="section__head">
          <span class="tc-label">Within {city.city}</span>
          <h2 class="tc-h3">Districts &amp; neighbourhoods</h2>
        </div>
        <div class="grid grid--cities">
          {districts.map((d) => <CityCard city={d} bed="three" />)}
        </div>
        <p class="tc-xs tc-muted" style="margin-top:12px">Area-level prices inside {city.city}. The figures above are for {city.city} as a whole.</p>
      </div>
    </section>
  )}

  {city.airports && city.airports.length > 0 && (
    <section class="section" style="padding-top:0">
      <div class="container">
        <div class="section__head">
          <span class="tc-label">Getting there</span>
          <h2 class="tc-h3">Nearest airports</h2>
        </div>
        <div class="grid grid--airports">
          {city.airports.map((a) => (
            <a class="tc-card airportcard" href={a.url} target="_blank" rel="noopener">
              <div class="airportcard__head">
                <span class="airportcard__code">{a.iata || a.icao}</span>
                <span class="airportcard__dist">{a.distance_km} km</span>
              </div>
              <span class="airportcard__name">{a.name}</span>
              {(a.destinations || a.airlines) && (
                <span class="airportcard__meta">
                  {a.destinations ? `${a.destinations} destinations` : ''}{a.destinations && a.airlines ? ' · ' : ''}{a.airlines ? `${a.airlines} airlines` : ''}
                </span>
              )}
              <span class="airportcard__cta">Routes &amp; flights →</span>
            </a>
          ))}
        </div>
        <p class="tc-xs tc-muted" style="margin-top:12px">Scheduled-service airports near {city.city}, nearest first. Flight data from <a href="https://www.airportroutes.com/" target="_blank" rel="noopener" style="color:var(--primary)">AirportRoutes</a>.</p>
      </div>
    </section>
  )}

  {related.length > 0 && (
    <section class="section section--tint" style="padding-top:48px">
      <div class="container">
        <div class="section__head">
          <span class="tc-label">More in {city.country}</span>
          <h2 class="tc-h3">Related locations</h2>
        </div>
        <div class="grid grid--cities">
          {related.map((c) => <CityCard city={c} bed="three" />)}
        </div>
      </div>
    </section>
  )}

  <section class="section">
    <div class="container affordline">
      <a class="tc-btn tc-btn--primary tc-btn--lg" href={`/compare/?a=${encodeURIComponent(city.slug)}`}>
        <span data-lucide="git-compare" style="width:18px;height:18px"></span>
        Compare {city.city} with another city
      </a>
      <a class="tc-btn tc-btn--secondary tc-btn--lg" href={`/contribute/?city=${encodeURIComponent(city.slug)}`}>
        <span data-lucide="pencil" style="width:18px;height:18px"></span>
        Suggest a price update
      </a>
    </div>
  </section>
</Base>
