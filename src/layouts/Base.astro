---
import '../styles/colors_and_type.css';
import '../styles/components.css';
import '../styles/site.css';
import { CITY_COUNT, COUNTRY_COUNT, DATA_UPDATED } from '../lib/data';

export interface Props {
  title: string;
  description: string;
  path: string; // canonical path, e.g. "/rankings/most-expensive-3-bed/"
  ogType?: string;
  jsonLd?: object | object[];
  noindex?: boolean;
}

const { title, description, path, ogType = 'website', jsonLd, noindex = false } = Astro.props;
const site = 'https://www.trendingcities.com';
const canonical = site + path;
const ogImage = site + '/og-default.png';
const jsonLdArr = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  {noindex
    ? <meta name="robots" content="noindex, nofollow" />
    : <meta name="robots" content="index, follow, max-image-preview:large" />}
  <meta name="theme-color" content="#1F62E8" />
  <link rel="icon" type="image/svg+xml" href="/assets/logo-mark.svg" />
  <link rel="sitemap" href="/sitemap-index.xml" />

  <!-- Open Graph -->
  <meta property="og:type" content={ogType} />
  <meta property="og:site_name" content="TrendingCities" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:image" content={ogImage} />
  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />

  {jsonLdArr.map((obj) => (
    <script type="application/ld+json" set:html={JSON.stringify(obj)} />
  ))}

  <!-- Privacy-friendly analytics by Plausible -->
  <script is:inline async src="https://my.sitemetrics.app/js/pa-6JG2UN4xceD2N0AOrWLds.js"></script>
  <script is:inline>
    window.plausible=window.plausible||function(){(plausible.q=plausible.q||[]).push(arguments)},plausible.init=plausible.init||function(i){plausible.o=i||{}};
    plausible.init()
  </script>
</head>
<body class="tc">
  <a href="#main" class="tc-skip">Skip to content</a>
  <header class="site-header">
    <div class="site-header__inner">
      <a class="brand" href="/" aria-label="TrendingCities home">
        <img src="/assets/logo-mark.svg" alt="" width="28" height="28" />
        <span class="brand__word"><span>Trending</span><span class="brand__accent">Cities</span></span>
      </a>
      <nav class="site-nav" aria-label="Primary">
        <a href="/rankings/most-expensive-3-bed/">Rankings</a>
        <a href="/compare/">Compare</a>
        <a href="/data/">Data &amp; methodology</a>
      </nav>
      <div class="nav-search" data-search>
        <span class="nav-search__icon" data-lucide="search" aria-hidden="true"></span>
        <input type="search" class="nav-search__input" placeholder="Search 400+ cities" aria-label="Search cities" autocomplete="off" data-search-input />
        <div class="search-results" data-search-results hidden></div>
      </div>
    </div>
  </header>

  <main id="main">
    <slot />
  </main>

  <footer class="site-footer">
    <div class="site-footer__inner">
      <div class="site-footer__brand">
        <a class="brand" href="/">
          <img src="/assets/logo-mark.svg" alt="" width="24" height="24" />
          <span class="brand__word"><span>Trending</span><span class="brand__accent">Cities</span></span>
        </a>
        <p class="tc-sm tc-secondary">Compare home prices across {CITY_COUNT} cities in {COUNTRY_COUNT} countries. Starter median-price data, {DATA_UPDATED}.</p>
      </div>
      <nav class="site-footer__cols" aria-label="Footer">
        <div>
          <span class="tc-label">Rankings</span>
          <a href="/rankings/most-expensive-3-bed/">Most expensive (3-bed)</a>
          <a href="/rankings/most-affordable-1-bed/">Most affordable (1-bed)</a>
          <a href="/rankings/best-2-bed-under-250k/">Best 2-bed under $250k</a>
          <a href="/rankings/country-comparison/">Country comparison</a>
        </div>
        <div>
          <span class="tc-label">Product</span>
          <a href="/compare/">Compare cities</a>
          <a href="/data/">Data &amp; methodology</a>
        </div>
      </nav>
    </div>
    <div class="site-footer__legal tc-xs tc-muted">
      <span>© 2026 TrendingCities</span>
      <span>Starter median-price data ({DATA_UPDATED}) — directional only. Full provenance &amp; methodology in progress.</span>
    </div>
  </footer>

  <script src="https://unpkg.com/lucide@latest"></script>
  <script>
    // @ts-nocheck
    function initIcons() { if (window.lucide) window.lucide.createIcons({ attrs: { 'stroke-width': 1.9 } }); }
    initIcons();

    // Site-wide city search (vanilla, no framework)
    let INDEX = null;
    async function loadIndex() {
      if (INDEX) return INDEX;
      const res = await fetch('/search-index.json');
      INDEX = await res.json();
      return INDEX;
    }
    document.querySelectorAll('[data-search]').forEach((box) => {
      const input = box.querySelector('[data-search-input]');
      const out = box.querySelector('[data-search-results]');
      if (!input || !out) return;
      let active = -1, items = [];
      const render = (list) => {
        items = list;
        active = -1;
        if (!list.length) { out.hidden = true; out.innerHTML = ''; return; }
        out.innerHTML = list.map((c, i) =>
          `<a class="search-results__item" href="${c.url}" data-i="${i}"><span>${c.city}</span><span class="tc-mono tc-muted">${c.country}</span></a>`
        ).join('');
        out.hidden = false;
      };
      const search = async (q) => {
        q = q.trim().toLowerCase();
        if (q.length < 2) { render([]); return; }
        const idx = await loadIndex();
        const starts = [], contains = [];
        for (const c of idx) {
          const cl = c.city.toLowerCase();
          if (cl.startsWith(q)) starts.push(c);
          else if (cl.includes(q) || c.country.toLowerCase().includes(q)) contains.push(c);
          if (starts.length >= 8) break;
        }
        render(starts.concat(contains).slice(0, 8));
      };
      input.addEventListener('input', (e) => search(e.target.value));
      input.addEventListener('keydown', (e) => {
        if (out.hidden) return;
        const links = [...out.querySelectorAll('.search-results__item')];
        if (e.key === 'ArrowDown') { e.preventDefault(); active = Math.min(active + 1, links.length - 1); }
        else if (e.key === 'ArrowUp') { e.preventDefault(); active = Math.max(active - 1, 0); }
        else if (e.key === 'Enter' && active >= 0) { e.preventDefault(); window.location.href = links[active].href; return; }
        else if (e.key === 'Escape') { render([]); return; }
        links.forEach((l, i) => l.setAttribute('aria-selected', i === active ? 'true' : 'false'));
      });
      document.addEventListener('click', (e) => { if (!box.contains(e.target)) { out.hidden = true; } });
    });
  </script>
</body>
</html>
